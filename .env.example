# Non-sensitive runtime settings
DATA_CACHE_DIR=backend/ml/cache
ARTIFACT_DIR=backend/ml/artifacts
POSTGRES_HOST=postgres
POSTGRES_DB=commodity
FRONTEND_URL=http://localhost:5173
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CALLBACK_URL=http://localhost:8000/api/auth/callback
AUTH0_AUDIENCE=
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
VITE_AUTH0_AUDIENCE=
VITE_AUTH0_CALLBACK_URL=http://localhost:5173
VITE_API_BASE_URL=/api

# Infisical runtime auth (required for sensitive secrets)
INFISICAL_PROJECT_ID=b4cbedee-a322-483a-a1d6-8183713b5bb9
INFISICAL_ENV=dev
# Provide either a short-lived machine identity token...
INFISICAL_TOKEN=
# ...or client credentials for universal-auth login at runtime
INFISICAL_CLIENT_ID=d96db8d8-109d-4e90-abb6-087c6c08b82f
INFISICAL_CLIENT_SECRET=77e0d594b9660a862385e391d9cd482d8efaa193d2a285e93b4ed7eededf2c90
INFISICAL_API_URL=
INFISICAL_CACHE_TTL_SECONDS=1800
INFISICAL_REFRESH_INTERVAL_SECONDS=1800
INFISICAL_TOKEN_REFRESH_INTERVAL_SECONDS=600
INFISICAL_MAX_RETRIES=3
INFISICAL_RETRY_BACKOFF_SECONDS=1.0

# Optional operational settings
WHATSAPP_PROVIDER=twilio
WHATSAPP_META_API_VERSION=v20.0
REDIS_URL=redis://localhost:6379/0
WHATSAPP_RATE_LIMIT_WINDOW_SECONDS=3600
WHATSAPP_RATE_LIMIT_MAX_MESSAGES=5
WHATSAPP_ALERT_POLL_INTERVAL_SECONDS=60
WHATSAPP_WORKER_ENABLED=true
AI_CHAT_PROVIDER=gemini
OPENAI_CHAT_MODEL=gpt-5.2
OPENAI_FALLBACK_MODELS=gpt-5,gpt-4.1,gpt-4o-mini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-1.5-flash
ANTHROPIC_MODEL=claude-3-5-haiku-latest
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Optional model switches
ENABLE_CHRONOS_BOLT=false
DISABLE_XGBOOST=false
