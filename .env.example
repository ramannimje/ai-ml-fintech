METALS_API_KEY=YOUR_API_KEY_HERE
DATA_CACHE_DIR=backend/ml/cache
ARTIFACT_DIR=backend/ml/artifacts

# Auth0 Setup Steps:
# 1. Go to auth0.com -> Create Account -> Create Tenant
# 2. Applications -> Create Application -> Single Page App
# 3. Enable Google, Facebook, Microsoft in Authentication -> Social
# 4. Set Allowed Callback URLs:
#    http://localhost:5173, http://127.0.0.1:5173, http://localhost:8000/api/auth/callback
# 5. Set Allowed Logout URLs: http://localhost:5173, http://127.0.0.1:5173
# 6. Set Allowed Web Origins: http://localhost:5173, http://127.0.0.1:5173
# 7. Copy Domain, Client ID, Client Secret to .env
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_CALLBACK_URL=http://localhost:8000/api/auth/callback
AUTH0_AUDIENCE=
FRONTEND_URL=http://localhost:5173
SECRET_KEY=change-this-secret-key-32-chars-min

VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
VITE_AUTH0_AUDIENCE=
VITE_AUTH0_CALLBACK_URL=http://localhost:5173
VITE_API_BASE_URL=/api

# Optional email providers for price alerts (free tiers available)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@example.com

# Optional WhatsApp alert providers
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_API_VERSION=v20.0
REDIS_URL=redis://localhost:6379/0
WHATSAPP_RATE_LIMIT_WINDOW_SECONDS=3600
WHATSAPP_RATE_LIMIT_MAX_MESSAGES=5
WHATSAPP_ALERT_POLL_INTERVAL_SECONDS=60
WHATSAPP_WORKER_ENABLED=true

# Optional AI news summarization keys
NEWSAPI_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# AI chat provider: gemini | openai | ollama | disabled
AI_CHAT_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-1.5-flash
OPENAI_API_KEY=
# Preferred OpenAI model (set to a valid model in your account; e.g. gpt-5.2 or latest alias).
OPENAI_CHAT_MODEL=gpt-5.2
# Comma-separated fallbacks tried automatically when the preferred model is unavailable.
OPENAI_FALLBACK_MODELS=gpt-5,gpt-4.1,gpt-4o-mini
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Optional: enable Chronos-Bolt model candidate during training
# Requires chronos-forecasting + a torch build compatible with your host.
ENABLE_CHRONOS_BOLT=false

# Optional: disable XGBoost candidate (useful on constrained environments)
DISABLE_XGBOOST=false
